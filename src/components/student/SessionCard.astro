---
import { format } from 'date-fns';
import { es } from 'date-fns/locale';

interface Props {
  session: any;
  href: string;
  compact?: boolean;
}

const { session, href, compact = false } = Astro.props;
const statusClass = `status-${session.status}`;
const durationMinutes = Math.round(session.duration / 60);
---

<article class="card-surface p-4 space-y-3">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="mono text-xs text-slate-400">{format(new Date(session.date), 'PPpp', { locale: es })}</p>
      <h3 class="text-lg font-semibold mt-1">{session.courseName}</h3>
      <p class="text-sm text-slate-400 mt-1">{session.teacherName}</p>
    </div>
    <span class={`status-badge ${statusClass}`}>{session.status}</span>
  </div>

  <div class="text-sm text-slate-300 flex flex-wrap gap-x-4 gap-y-1">
    <span>{durationMinutes} min</span>
    {!compact && <span>{session.speakerCount || '-'} participantes</span>}
  </div>

  <div class="flex flex-wrap gap-2">
    {session.topics?.map((topic: string) => (
      <span class="text-xs border border-cyan-500/30 text-cyan-200 rounded-full px-2 py-1">{topic}</span>
    ))}
  </div>

  {session.status === 'processing' && (
    <div class="w-full h-2 rounded-full bg-slate-700/40 overflow-hidden">
      <div class="processing-bar h-full"></div>
    </div>
  )}

  <a class="interactive inline-flex mt-1 text-cyan-300 hover:text-cyan-200" href={href}>Ver sesion -></a>
</article>

<style>
  .processing-bar {
    width: 42%;
    background: linear-gradient(90deg, var(--accent-amber), var(--accent-cyan));
    animation: load-bar 1.2s ease-in-out infinite;
  }

  @keyframes load-bar {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(200%);
    }
  }
</style>
