---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import sessions from '../../data/sessions.json';
import { format } from 'date-fns';

const teacherSessions = sessions.filter((session) => session.teacherId === 'teacher-001').sort((a, b) => +new Date(b.date) - +new Date(a.date));
---

<DashboardLayout role="teacher" title="Historial | Docente">
  <section class="card-surface p-4 overflow-x-auto">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="text-left text-slate-400">
          <th>Sesion</th>
          <th>Fecha</th>
          <th>Estado</th>
          <th>WER</th>
          <th>DER</th>
          <th>Participantes</th>
          <th>Filtrados</th>
          <th>Detalle</th>
        </tr>
      </thead>
      <tbody>
        {teacherSessions.map((session) => (
          <tr class="border-t border-cyan-900/30">
            <td>{session.courseName}</td>
            <td>{format(new Date(session.date), 'yyyy-MM-dd HH:mm')}</td>
            <td><span class={`status-badge status-${session.status}`}>{session.status}</span></td>
            <td>{session.wer || '--'}%</td>
            <td>{session.der || '--'}%</td>
            <td>{session.speakerCount || '--'}</td>
            <td>{session.totalSegments && session.relevantSegments ? session.totalSegments - session.relevantSegments : '--'}</td>
            <td><a href={`/teacher/session/${session.id}`} class="text-cyan-300">Abrir -></a></td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</DashboardLayout>
